services:
  app:
    image: {{ manifest.app.name }}:{{ manifest.app.version }}
    container_name: swiftdeploy-app
    restart: unless-stopped
    user: "1001:1001"
    cap_drop:
      - ALL
    environment:
      - MODE={{ manifest.app.mode }}
      - APP_VERSION={{ manifest.app.version }}
      - APP_PORT={{ manifest.app.port }}
    networks:
      - {{ manifest.network.name }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ manifest.app.port }}/healthz"]
      interval: 10s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true

  nginx:
    image: {{ manifest.nginx.image }}
    container_name: swiftdeploy-nginx
    restart: unless-stopped
    ports:
      - "{{ manifest.nginx.port }}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - nginx_logs:/var/log/nginx
    depends_on:
      - app
    networks:
      - {{ manifest.network.name }}

networks:
  {{ manifest.network.name }}:
    driver: {{ manifest.network.driver }}

volumes:
  nginx_logs:
